# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# These NEXT_PUBLIC_ prefixed vars are required by the Next.js browser client
# Set them to the same values as SUPABASE_URL and SUPABASE_ANON_KEY above
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App
APP_URL=http://localhost:3000
# Local dev (two processes): API on 4000. Production single server (`npm start`): omit or leave empty so the browser uses the same origin.
NEXT_PUBLIC_API_URL=http://localhost:4000
# When Meta requires HTTPS for OAuth (recommended): use root `npm run dev:https`, then e.g.
#   APP_URL=https://localhost:3000
#   NEXT_PUBLIC_API_URL=https://localhost:3000
#   IG_REDIRECT_URI=https://localhost:3000/api/auth/instagram/callback
# Next.js dev proxies /api/* → Express; keep API on 4000 (default INTERNAL_API_ORIGIN below).
# INTERNAL_API_ORIGIN=http://127.0.0.1:4000

# Anthropic (content plan generation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Razorpay (credit purchases)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Instagram / Facebook Graph API
# App: https://developers.facebook.com/apps — create a Meta app, add "Facebook Login" and use
# "Instagram API with Facebook Login" (Graph), not the legacy "Instagram Basic Display" product.
#
# IG_APP_ID = Settings → Basic → "App ID" (digits only). Must match the app that owns Facebook Login.
# If Facebook shows PLATFORM__INVALID_APP_ID, you almost always have the wrong ID:
#   - Wrong: "Instagram App ID" from Basic Display settings (different from Facebook App ID).
#   - Wrong: copied Client Token, App Secret, or a numeric ID from another / deleted app.
#   - Fix: App settings → Basic → copy App ID again; ensure no extra characters in .env.
IG_APP_ID=1234567890123456
IG_APP_SECRET=your-facebook-app-secret
# Must match Meta → Facebook Login → Settings → Valid OAuth redirect URIs (exact string).
# Production: https://YOUR_DOMAIN/api/auth/instagram/callback
# Local: Meta often requires HTTPS — then use the https line + `npm run dev:https` (see APP_URL block above).
IG_REDIRECT_URI=http://localhost:4000/api/auth/instagram/callback
# IG_REDIRECT_URI=https://localhost:3000/api/auth/instagram/callback

# Token encryption — AES-256-CBC key (64 hex chars = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate-a-64-char-hex-string-here

# OAuth state signing — any long random string
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-random-secret-here
