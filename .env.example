# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# These NEXT_PUBLIC_ prefixed vars are required by the Next.js browser client
# Set them to the same values as SUPABASE_URL and SUPABASE_ANON_KEY above
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Anthropic (content plan generation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Razorpay (credit purchases)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Instagram / Facebook Graph API
# Create a Facebook App at developers.facebook.com → Add Instagram Graph API product
IG_APP_ID=your-facebook-app-id
IG_APP_SECRET=your-facebook-app-secret
# Must match the OAuth redirect URI registered in your Facebook App settings
# Points to the Express API (port 4000), NOT the Next.js frontend
IG_REDIRECT_URI=http://localhost:4000/api/auth/instagram/callback

# Token encryption — AES-256-CBC key (64 hex chars = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate-a-64-char-hex-string-here

# OAuth state signing — any long random string
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-random-secret-here
