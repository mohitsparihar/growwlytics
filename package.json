{
  "name": "growwlytics",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/web\" \"npm run dev --workspace=apps/api\"",
    "build": "npm run build --workspace=packages/types && npm run build --workspace=apps/web && npm run build --workspace=apps/api",
    "start": "node serve-production.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "verify:supabase": "node scripts/verify-supabase-url.mjs"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
